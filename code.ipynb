
import yfinance as yf
import pandas as pd
import numpy as np
import requests
from bs4 import BeautifulSoup
import plotly.graph_objects as go
from plotly.subplots import make_subplots
import plotly.express as px
import warnings
warnings.filterwarnings('ignore')

# revenue data extraction
import re
class StockAnalysisDashboard:
    def __init__(self, stocks):
        self.stocks = stocks
        self.stock_data = {}
        self.revenue_data = {}
    def extract_stock_prices(self, period='2y'):
        print("Extracting the historical stock prices...")
        for stock in self.stocks:
            try:
                ticker = yf.Ticker(stock)
                self.stock_data[stock] = ticker.history(period=period)
                print("Successfully extracted data for "+stock)
            except Exception as e:
                print("Error extracting data for "+stock+" : "+str(e))
        return self.stock_data
    def extract_revenue_macrotrends(self, stock_name, ticker):
        try:
            # Map stock names to  URLs
            url_map = {
                'TSLA': 'https://www.macrotrends.net/stocks/charts/TSLA/tesla/revenue',
                'AMZN': 'https://www.macrotrends.net/stocks/charts/AMZN/amazon/revenue',
                'AMD': 'https://www.macrotrends.net/stocks/charts/AMD/amd/revenue',
                'GME': 'https://www.macrotrends.net/stocks/charts/GME/gamestop/revenue'
            }
            url = url_map.get(ticker)
            if not url:
                return None
            headers = {
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
            }
            
            response = requests.get(url, headers=headers)
            soup = BeautifulSoup(response.content, 'html.parser')
            
            # Find the revenue table
            tables = soup.find_all('table')
            revenue_data = []
            
            for table in tables:
                rows = table.find_all('tr')
                for row in rows[1:13]:  
                    cols = row.find_all('td')
                    if len(cols) >= 2:
                        date = cols[0].text.strip()
                        revenue = cols[1].text.strip()
                        
                        # Clean revenue data
                        revenue_clean = re.sub(r'[^0-9.]', '', revenue)
                        if revenue_clean:
                            revenue_data.append({
                                'Date': date,
                                'Revenue': float(revenue_clean) if revenue_clean else 0
                            })
            
            if revenue_data:
                df_revenue = pd.DataFrame(revenue_data)
                df_revenue['Date'] = pd.to_datetime(df_revenue['Date'])
                df_revenue = df_revenue.sort_values('Date')
                return df_revenue
                
        except Exception as e:
            print(f"Error scraping revenue for {stock_name}: {e}")
            return None
    
    def extract_revenue_alternative(self, ticker):
        try:
            stock = yf.Ticker(ticker)
            quarterly_financials = stock.quarterly_financials
            
            if 'Total Revenue' in quarterly_financials.index:
                revenue_series = quarterly_financials.loc['Total Revenue']
                df_revenue = pd.DataFrame({
                    'Date': revenue_series.index,
                    'Revenue': revenue_series.values / 1e6 
                })
                return df_revenue
        except Exception as e:
            print(f"Alternative revenue extraction failed for {ticker}: {e}")
            return None
    
    def calculate_metrics(self):
     
        metrics = {}
        
        for stock, data in self.stock_data.items():
            if not data.empty:
                latest_price = data['Close'].iloc[-1]
                avg_price = data['Close'].mean()
                max_price = data['Close'].max()
                min_price = data['Close'].min()
                volatility = data['Close'].pct_change().std() * np.sqrt(252)  # Annualized volatility
                
                # Calculate returns
                data['Returns'] = data['Close'].pct_change()
                cumulative_return = (data['Close'].iloc[-1] / data['Close'].iloc[0] - 1) * 100
                
                # Calculate moving averages
                data['MA20'] = data['Close'].rolling(window=20).mean()
                data['MA50'] = data['Close'].rolling(window=50).mean()
                
                metrics[stock] = {
                    'Latest Price': f"${latest_price:.2f}",
                    'Average Price': f"${avg_price:.2f}",
                    '52-Week High': f"${max_price:.2f}",
                    '52-Week Low': f"${min_price:.2f}",
                    'Volatility (Annual)': f"{volatility:.2%}",
                    'Cumulative Return': f"{cumulative_return:.2f}%",
                    'Trading Days': len(data)
                }
                
                self.stock_data[stock] = data
                
        return metrics
    
    def create_price_chart(self):
 
        fig = make_subplots(
            rows=2, cols=2,
            subplot_titles=(f'{list(self.stocks)[0]} Price Trend', 
                          f'{list(self.stocks)[1]} Price Trend',
                          f'{list(self.stocks)[2]} Price Trend', 
                          f'{list(self.stocks)[3]} Price Trend'),
            vertical_spacing=0.12,
            horizontal_spacing=0.1
        )
        
        row_col_map = [(1,1), (1,2), (2,1), (2,2)]
        
        for idx, stock in enumerate(self.stocks):
            row, col = row_col_map[idx]
            data = self.stock_data[stock]
            
            # Add candlestick chart
            fig.add_trace(
                go.Candlestick(
                    x=data.index,
                    open=data['Open'],
                    high=data['High'],
                    low=data['Low'],
                    close=data['Close'],
                    name=f'{stock} Price',
                    showlegend=False
                ),
                row=row, col=col
            )
            
            # Add moving averages
            fig.add_trace(
                go.Scatter(
                    x=data.index,
                    y=data['MA20'],
                    name='MA20',
                    line=dict(color='orange', width=1),
                    showlegend=False
                ),
                row=row, col=col
            )
            
            fig.add_trace(
                go.Scatter(
                    x=data.index,
                    y=data['MA50'],
                    name='MA50',
                    line=dict(color='blue', width=1),
                    showlegend=False
                ),
                row=row, col=col
            )
            
            # Update layout for each subplot
            fig.update_xaxes(title_text="Date", row=row, col=col)
            fig.update_yaxes(title_text="Price (USD)", row=row, col=col)
        
        fig.update_layout(
            title="Stock Price Trends with the Moving Averages",
            xaxis_title="Date",
            yaxis_title="Price (USD)",
            template="plotly_dark",
            height=800,
            showlegend=True
        )
        
        return fig
    
    def create_returns_comparison(self):
        fig = go.Figure()
        
        for stock in self.stocks:
            data = self.stock_data[stock]
            cumulative_returns = (1 + data['Returns']).cumprod() - 1
            cumulative_returns_percent = cumulative_returns * 100
            
            fig.add_trace(go.Scatter(
                x=data.index,
                y=cumulative_returns_percent,
                mode='lines',
                name=stock,
                line=dict(width=2)
            ))
        
        fig.update_layout(
            title="Cumulative Returns of  Comparison (%)",
            xaxis_title="Date",
            yaxis_title="Cumulative Return (%)",
            template="plotly_dark",
            hovermode='x unified',
            height=500
        )
        
        return fig
    
    def create_volatility_chart(self):
        fig = go.Figure()
        
        for stock in self.stocks:
            data = self.stock_data[stock]
            rolling_vol = data['Returns'].rolling(window=30).std() * np.sqrt(252) * 100
            
            fig.add_trace(go.Scatter(
                x=data.index,
                y=rolling_vol,
                mode='lines',
                name=stock,
                line=dict(width=2)
            ))
        
        fig.update_layout(
            title="Rolling 30-Day of  Annualized Volatility (%)",
            xaxis_title="Date",
            yaxis_title="Volatility (%)",
            template="plotly_dark",
            hovermode='x unified',
            height=500
        )
        
        return fig
    
    def create_revenue_chart(self):
        fig = go.Figure()
        
        for stock in self.stocks:
            if stock in self.revenue_data and self.revenue_data[stock] is not None:
                rev_data = self.revenue_data[stock]
                
                fig.add_trace(go.Bar(
                    x=rev_data['Date'],
                    y=rev_data['Revenue'],
                    name=f'{stock} Revenue',
                    text=rev_data['Revenue'].apply(lambda x: f'${x:.0f}M'),
                    textposition='outside'
                ))
        
        if len(fig.data) > 0:
            fig.update_layout(
                title="Quarterly Revenue in  Comparison (in Millions USD)",
                xaxis_title="Quarter",
                yaxis_title="Revenue (Millions USD)",
                template="plotly_dark",
                barmode='group',
                height=500,
                showlegend=True
            )
        
        return fig
    
    def create_performance_heatmap(self):

        all_returns = {}
        
        for stock in self.stocks:
            data = self.stock_data[stock]
            monthly_returns = data['Returns'].resample('ME').apply(lambda x: (1 + x).prod() - 1) * 100
            monthly_returns = monthly_returns.to_frame(name=stock)
            all_returns[stock] = monthly_returns
        
        # Combine all returns
        combined_returns = pd.concat(all_returns, axis=1)
        combined_returns.columns = self.stocks
        
        # Create heatmap
        fig = px.imshow(
            combined_returns.T,
            text_auto='.1f',
            aspect="auto",
            color_continuous_scale='RdYlGn',
            title="Monthly Returns Heatmap (%)",
            labels=dict(x="Month", y="Stock", color="Return (%)")
        )
        
        fig.update_layout(
            template="plotly_dark",
            height=600
        )
        
        return fig
    
    def create_dashboard(self):

        print("\n" + "="*60)
        print("STOCK ANALYSIS DASHBOARD")
        print("="*60)
        
        # Calculate metrics
        metrics = self.calculate_metrics()
        
        # Display metrics table
        print("\nKEY METRICS SUMMARY")
        print("-"*60)
        metrics_df = pd.DataFrame(metrics).T
        print(metrics_df.to_string())
        
        # Create visualizations
        print("\nGenerating visualizations...")
        
        fig1 = self.create_price_chart()
        fig2 = self.create_returns_comparison()
        fig3 = self.create_volatility_chart()
        fig4 = self.create_revenue_chart()
        fig5 = self.create_performance_heatmap()
        
        # Show all figures
        fig1.show()
        fig2.show()
        fig3.show()
        
        if len(fig4.data) > 0:
            fig4.show()
        else:
            print("\nRevenue data are not available for visualization")
        
        fig5.show()
        
        return {
            'metrics': metrics_df,
            'price_chart': fig1,
            'returns_chart': fig2,
            'volatility_chart': fig3,
            'revenue_chart': fig4,
            'heatmap': fig5
        }

# Main execution
def main():
    # Define s
    stocks = ['TSLA', 'AMZN', 'AMD', 'GME']
    stock_names = {
        'TSLA': 'Tesla',
        'AMZN': 'Amazon',
        'AMD': 'AMD',
        'GME': 'GameStop'
    }
    
    # Initialize dashboard
    dashboard = StockAnalysisDashboard(stocks)
    
    # Extract stock prices
    print("Step 1: Extracting Stock Price Data")
    print("-" * 40)
    stock_data = dashboard.extract_stock_prices(period='2y')
    
    # Extract revenue data
    print("\nStep 2: Extracting Revenue Data")
    print("-" * 40)
    for stock in stocks:
        print(f"Extracting revenue for {stock_names[stock]}...")
        revenue = dashboard.extract_revenue_alternative(stock)
        if revenue is not None and not revenue.empty:
            dashboard.revenue_data[stock] = revenue
            print(f"Revenue data extracted for {stock_names[stock]}")
        else:
            print(f"Using alternative method for {stock_names[stock]}...")
            revenue = dashboard.extract_revenue_macrotrends(stock_names[stock], stock)
            if revenue is not None:
                dashboard.revenue_data[stock] = revenue
                print(f"Revenue data extracted for {stock_names[stock]} via web scraping")
            else:
                print(f"Could not extract revenue data for {stock_names[stock]}")
    
    # Create dashboard
    print("\nStep 3: Creating Interactive Dashboard")
    print("-" * 40)
    dashboard_results = dashboard.create_dashboard()
    
    # Generate insights report
    print("\n" + "="*60)
    print("KEY INSIGHTS AND RECOMMENDATIONS")
    print("="*60)
    
    metrics = dashboard_results['metrics']
    
    # Analyze performance
    best_performer = metrics['Cumulative Return'].str.rstrip('%').astype(float).idxmax()
    worst_performer = metrics['Cumulative Return'].str.rstrip('%').astype(float).idxmin()
    most_volatile = metrics['Volatility (Annual)'].str.rstrip('%').astype(float).idxmax()
    
    print(f"\n Top Performer: {best_performer} with {metrics.loc[best_performer, 'Cumulative Return']} return")
    print(f"  Most Volatile: {most_volatile} with {metrics.loc[most_volatile, 'Volatility (Annual)']} annual volatility")
    
    print("\n Investment Recommendations:")
    print("-" * 40)
    
    for stock in stocks:
        ret = float(metrics.loc[stock, 'Cumulative Return'].rstrip('%'))
        vol = float(metrics.loc[stock, 'Volatility (Annual)'].rstrip('%'))
        
        if ret > 20 and vol < 40:
            print(f" {stock}: STRONG BUY - Excellent returns with moderate volatility")
        elif ret > 10 and vol < 50:
            print(f"{stock}: BUY - Positive returns with acceptable risk")
        elif ret > 0:
            print(f"{stock}: HOLD - Stable performance, monitor for better entry points")
        else:
            print(f"{stock}: CONSIDER SELLING - Negative returns, high risk")
    
    print("\n" + "="*60)
    print("Dashboard creation is completed. All visualizations should now be displayed.")
    print("="*60)

# Run the dashboard
if __name__ == "__main__":
    main()
